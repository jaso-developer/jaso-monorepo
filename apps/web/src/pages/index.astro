---
/**
 * Página principal de jaso.me
 *
 * Esta es la página hub — presenta las dos facetas
 * de José y dirige a cada sección del monorepo.
 */
import BaseLayout from "@jaso/ui-astro/components/BaseLayout.astro"
import Card       from "@jaso/ui-astro/components/Card.astro"
import { readingTime } from "@jaso/utils"

// Importa las notas más recientes de ambos mundos
const devNotes    = await Astro.glob("../../../../packages/content/dev/*.md")
const ganadoNotes = await Astro.glob("../../../../packages/content/ganado/*.md")

// Ordena por fecha descendente y toma las 3 más recientes de cada uno
const latestDev = devNotes
  .filter(n => !n.frontmatter.draft)
  .sort((a, b) =>
    new Date(b.frontmatter.pubDate).getTime() -
    new Date(a.frontmatter.pubDate).getTime()
  )
  .slice(0, 3)

const latestGanado = ganadoNotes
  .filter(n => !n.frontmatter.draft)
  .sort((a, b) =>
    new Date(b.frontmatter.pubDate).getTime() -
    new Date(a.frontmatter.pubDate).getTime()
  )
  .slice(0, 3)
---

<BaseLayout
  title="jaso.me"
  description="Sitio personal de José A. Silva — Desarrollo web y Ganadería."
  currentSite="web"
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__content">
      <p class="hero__greeting">Hola, soy</p>
      <h1 class="hero__name">José A. Silva</h1>
      <p class="hero__bio">
        Desarrollador web apasionado por la arquitectura de software
        y la ganadería sustentable. Dos mundos, una sola persona.
      </p>
    </div>
  </section>

  <!-- Dos mundos -->
  <section class="mundos" aria-label="Secciones del sitio">
    <a href="https://dev.jaso.me" class="mundo mundo--dev">
      <span class="mundo__emoji" aria-hidden="true">⌨️</span>
      <div>
        <h2 class="mundo__titulo">Desarrollo Web</h2>
        <p class="mundo__desc">
          Notas técnicas, proyectos y aprendizajes sobre
          JavaScript, TypeScript, Astro y arquitectura de software.
        </p>
      </div>
      <span class="mundo__arrow" aria-hidden="true">→</span>
    </a>

    <a href="https://ganado.jaso.me" class="mundo mundo--ganado">
      <span class="mundo__emoji" aria-hidden="true">🐄</span>
      <div>
        <h2 class="mundo__titulo">Ganadería</h2>
        <p class="mundo__desc">
          Notas de campo sobre manejo de praderas, nutrición,
          reproducción y gestión de hatos bovinos.
        </p>
      </div>
      <span class="mundo__arrow" aria-hidden="true">→</span>
    </a>
  </section>

  <!-- Últimas notas de Dev -->
  <section class="section">
    <div class="section__header">
      <h2 class="section__title">Últimas notas de Dev</h2>
      <a href="https://dev.jaso.me" class="section__link">
        Ver todas →
      </a>
    </div>
    <div class="grid">
      {latestDev.map(note => (
        <Card
          title={note.frontmatter.title}
          description={note.frontmatter.description}
          href={note.url}
          tags={note.frontmatter.tags}
          pubDate={note.frontmatter.pubDate}
          readingTime={readingTime(note.rawContent())}
        />
      ))}
    </div>
  </section>

  <!-- Últimas notas de Ganadería -->
  <section class="section">
    <div class="section__header">
      <h2 class="section__title">Últimas notas de Ganadería</h2>
      <a href="https://ganado.jaso.me" class="section__link">
        Ver todas →
      </a>
    </div>
    <div class="grid">
      {latestGanado.map(note => (
        <Card
          title={note.frontmatter.title}
          description={note.frontmatter.description}
          href={note.url}
          tags={note.frontmatter.tags}
          pubDate={note.frontmatter.pubDate}
          readingTime={readingTime(note.rawContent())}
        />
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────── */
  .hero {
    padding:    var(--space-20) 0 var(--space-16);
    text-align: center;
  }

  .hero__greeting {
    font-size:   var(--text-lg);
    color:       var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .hero__name {
    font-size:     var(--text-4xl);
    font-weight:   var(--font-bold);
    line-height:   var(--leading-tight);
    margin-bottom: var(--space-6);
    background:    linear-gradient(
      135deg,
      var(--color-primary) 0%,
      var(--color-accent)  100%
    );
    background-clip:         text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero__bio {
    font-size:  var(--text-lg);
    color:      var(--color-text-muted);
    max-width:  560px;
    margin:     0 auto;
    line-height: var(--leading-relaxed);
  }

  /* ── Dos mundos ────────────────────────────────── */
  .mundos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap:     var(--space-4);
    margin:  var(--space-8) 0 var(--space-16);
  }

  .mundo {
    display:         flex;
    align-items:     center;
    gap:             var(--space-4);
    padding:         var(--space-6);
    border:          1px solid var(--color-border);
    border-radius:   var(--radius-xl);
    text-decoration: none;
    color:           var(--color-text);
    transition:      all 0.2s ease;

    &:hover {
      border-color: var(--color-primary);
      box-shadow:   var(--shadow-md);
      transform:    translateY(-2px);
    }
  }

  .mundo--ganado:hover {
    border-color: var(--color-accent);
  }

  .mundo__emoji {
    font-size:  2.5rem;
    flex-shrink: 0;
  }

  .mundo__titulo {
    font-size:     var(--text-lg);
    font-weight:   var(--font-semibold);
    margin-bottom: var(--space-1);
  }

  .mundo__desc {
    font-size:   var(--text-sm);
    color:       var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .mundo__arrow {
    margin-left: auto;
    font-size:   var(--text-xl);
    color:       var(--color-text-muted);
    transition:  transform 0.2s ease;

    .mundo:hover & {
      transform: translateX(4px);
    }
  }

  /* ── Secciones ─────────────────────────────────── */
  .section {
    margin-bottom: var(--space-16);
  }

  .section__header {
    display:         flex;
    justify-content: space-between;
    align-items:     baseline;
    margin-bottom:   var(--space-8);
  }

  .section__title {
    font-size:   var(--text-2xl);
    font-weight: var(--font-bold);
  }

  .section__link {
    font-size:       var(--text-sm);
    color:           var(--color-primary);
    text-decoration: none;
    font-weight:     var(--font-medium);

    &:hover {
      text-decoration: underline;
    }
  }

  .grid {
    display:               grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap:                   var(--space-6);
  }
</style>