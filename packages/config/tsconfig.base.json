{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "strict":           true,
    "strictNullChecks": true,
    "skipLibCheck":     true,
    "noUnusedLocals":   true,
    "noUnusedParameters": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit":           true,
    "jsx":              "preserve"
  },
  "exclude": ["node_modules", "dist"]
}
